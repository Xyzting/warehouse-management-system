<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/dashboard_title"
            app:titleTextColor="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_welcome_placeholder"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_subtitle"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMasterData"
                style="@style/Widget.WMSMobile.MenuButton"
                android:text="@string/menu_master_data" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInbound"
                style="@style/Widget.WMSMobile.MenuButton"
                android:text="@string/menu_inbound" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOutbound"
                style="@style/Widget.WMSMobile.MenuButton"
                android:text="@string/menu_outbound" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInventory"
                style="@style/Widget.WMSMobile.MenuButton"
                android:text="@string/menu_inventory" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReporting"
                style="@style/Widget.WMSMobile.MenuButton"
                android:text="@string/menu_reporting" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_logout"
                android:layout_marginTop="24dp"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
